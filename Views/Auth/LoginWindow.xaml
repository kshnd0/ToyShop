<Window x:Class="ToyShop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="513" Width="429"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        Icon="/Images/logo.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0" 
                Background="#2C3E50" 
                CornerRadius="10" 
                Height="80" 
                Margin="0,0,0,25">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Orientation="Horizontal">

                <Image Source="/Images/logo.png" Width="64" Height="64" 
                       Margin="0,0,10,0"/>
                <TextBlock Text="ToyShop" FontSize="28" FontWeight="Bold" 
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>


        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Логин" FontSize="13" FontWeight="SemiBold" 
                       Foreground="#2C3E50" Margin="0,0,0,5"/>
            <TextBox x:Name="tbLogin" Height="40" FontSize="14" 
                     Padding="10" Background="White"
                     BorderBrush="#BDC3C7" BorderThickness="1"/>
        </StackPanel>


        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="Пароль" FontSize="13" FontWeight="SemiBold" 
                       Foreground="#2C3E50" Margin="0,0,0,5"/>
            <PasswordBox x:Name="pbPassword" Height="40" FontSize="14" 
                         Padding="10" Background="White"
                         BorderBrush="#BDC3C7" BorderThickness="1"/>
        </StackPanel>


        <Button x:Name="btnLogin" Grid.Row="3" 
                Content="ВОЙТИ" 
                Height="45" 
                FontSize="14" 
                FontWeight="Bold"
                Margin="0,0,0,15"
                Click="BtnLogin_Click"
                Background="#b5d5ca" 
                Foreground="White" 
                Cursor="Hand"/>


        <Border Grid.Row="4" Height="1" Background="#BDC3C7" Margin="0,5,0,15"/>


        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <TextBlock Text="Нет аккаунта?" 
                       FontSize="12" 
                       Foreground="#7F8C8D"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            <Button x:Name="btnRegister" 
                    Content="СОЗДАТЬ АККАУНТ" 
                    Height="40" 
                    FontSize="13" 
                    FontWeight="Bold"
                    Click="BtnRegister_Click"
                    Background="#d1eefc" 
                    Foreground="White" 
                    Cursor="Hand"/>
        </StackPanel>


        <TextBlock x:Name="tbError" Grid.Row="6" 
                   Foreground="#E74C3C" 
                   HorizontalAlignment="Center" 
                   FontSize="12" 
                   FontWeight="SemiBold"
                   Margin="0,10,0,0"/>


        <TextBlock x:Name="tbStatus" Grid.Row="7" 
                   FontSize="11" 
                   HorizontalAlignment="Center" 
                   Margin="0,15,0,0"
                   Foreground="#7F8C8D"/>
    </Grid>
</Window>