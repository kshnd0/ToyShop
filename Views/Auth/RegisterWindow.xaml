<Window x:Class="ToyShop.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="786" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#e1e1e1"
         Icon="/Images/logo.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" 
                Background="#2C3E50" CornerRadius="10" Height="70" Margin="0,0,0,20">
            <TextBlock Text="Регистрация нового пользователя" 
                       FontSize="18" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Имя -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" 
                   FontSize="14" FontWeight="Bold" 
                   VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbName" Grid.Row="1" Grid.Column="1" 
                 Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <!-- Фамилия -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Фамилия:" 
                   FontSize="14" FontWeight="Bold" 
                   VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbLastname" Grid.Row="2" Grid.Column="1" 
                 Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <!-- Логин -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Логин:" 
                   FontSize="14" FontWeight="Bold" 
                   VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbLogin" Grid.Row="3" Grid.Column="1" 
                 Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <!-- Пароль с глазиком -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Пароль:" 
                   FontSize="14" FontWeight="Bold" 
                   VerticalAlignment="Top" Margin="0,8,10,0"
                   Foreground="#000000"/>
        <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="pbPassword" Grid.Column="0" 
                             Height="35" Padding="8"
                             Background="White" BorderBrush="#b5d5ca" BorderThickness="1"
                             PasswordChanged="PbPassword_PasswordChanged"/>
                <TextBox x:Name="tbVisiblePassword" Grid.Column="0" 
                         Height="35" Padding="8" Visibility="Collapsed"
                         Background="White" BorderBrush="#b5d5ca" BorderThickness="1"
                         TextChanged="TbVisiblePassword_TextChanged"/>
                <Button Grid.Column="1" Content="👁️" Width="40" Height="35" 
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="TogglePasswordVisibility_Click" Margin="5,0,0,0"
                        FontSize="16"/>
            </Grid>

            <!-- Требования к паролю -->
            <Border Background="#FFF8E1" CornerRadius="8" Padding="10" Margin="0,8,0,0"
                    BorderBrush="#FFC107" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Требования к паролю:" FontSize="12" FontWeight="Bold"
                               Foreground="#E65100" Margin="0,0,0,8"/>
                    <TextBlock x:Name="tbLengthReq" Text="✗ Минимум 6 символов" 
                               FontSize="11" Foreground="Red" Margin="5,2"/>
                    <TextBlock x:Name="tbUpperReq" Text="✗ Минимум 1 прописная буква (A-Z)" 
                               FontSize="11" Foreground="Red" Margin="5,2"/>
                    <TextBlock x:Name="tbDigitReq" Text="✗ Минимум 1 цифра (0-9)" 
                               FontSize="11" Foreground="Red" Margin="5,2"/>
                    <TextBlock x:Name="tbSpecialReq" Text="✗ Минимум 1 спецсимвол (! @ # $ % ^)" 
                               FontSize="11" Foreground="Red" Margin="5,2"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Повтор пароля (исправлено) -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Повторите пароль:" 
                   FontSize="14" FontWeight="Bold" 
                   VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"
                   TextWrapping="Wrap"/>
        <PasswordBox x:Name="pbConfirmPassword" Grid.Row="5" Grid.Column="1" 
                     Height="35" Margin="0,0,0,10"
                     Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <!-- Телефон -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Телефон:" 
                   FontSize="14" FontWeight="Bold" 
                   VerticalAlignment="Top" Margin="0,8,10,0"
                   Foreground="#000000"/>
        <StackPanel Grid.Row="6" Grid.Column="1" Margin="0,0,0,10">
            <TextBox x:Name="tbNumber" Height="35" 
                     Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>
            <TextBlock Text="Формат: 8-XXX-XXX-XX-XX (пример: 8-999-123-45-67)" 
                       FontSize="10" Foreground="Gray" Margin="5,3,0,0"/>
        </StackPanel>

        <!-- Email -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Email:" 
                   FontSize="14" FontWeight="Bold" 
                   VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbEmail" Grid.Row="7" Grid.Column="1" 
                 Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnRegister" Content="Зарегистрироваться" 
                    Width="170" Height="40" Margin="0,0,15,0"
                    Click="BtnRegister_Click"
                    Background="#b5d5ca" Foreground="#000000" Cursor="Hand"/>
            <Button x:Name="btnCancel" Content="Отмена" 
                    Width="100" Height="40"
                    Click="BtnCancel_Click"
                    Background="#e0a9af" Foreground="#000000" Cursor="Hand"/>
        </StackPanel>

        <!-- Ошибка -->
        <TextBlock x:Name="tbError" Grid.Row="9" Grid.ColumnSpan="2" 
                   Foreground="Red" HorizontalAlignment="Center" 
                   FontSize="12" Margin="0,15,0,0"/>
    </Grid>
</Window>