<UserControl x:Class="ToyShop.Views.UserControls.EventsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#e1e1e1" CornerRadius="15" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="btnAdd" Content="Добавить акцию" 
                        Background="#b5d5ca" Foreground="Black"
                        Padding="15,8" Margin="0,0,10,0" Cursor="Hand"
                        Click="BtnAdd_Click"
                        Visibility="Collapsed"/>
                <Button x:Name="btnEdit" Content="Редактировать" 
                        Background="#d1eefc" Foreground="Black"
                        Padding="15,8" Margin="0,0,10,0" Cursor="Hand"
                        Click="BtnEdit_Click"
                        Visibility="Collapsed"/>
                <Button x:Name="btnDelete" Content="Удалить" 
                        Background="#e0a9af" Foreground="Black"
                        Padding="15,8" Cursor="Hand"
                        Click="BtnDelete_Click"
                        Visibility="Collapsed"/>
            </StackPanel>

            <TextBlock Text="Акции и скидки" FontSize="20" FontWeight="Bold" 
                       Foreground="#000000" Margin="0,0,0,15" Grid.Row="1"/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icEvents">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12" 
                                    Margin="10" Padding="15"
                                    BorderBrush="#b5d5ca" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonUp="Card_Click" Tag="{Binding IdEvent}">
                                <StackPanel>
                                    <TextBlock Text="{Binding EventName}" 
                                               FontSize="18" FontWeight="Bold" 
                                               Foreground="#2C3E50"
                                               Margin="0,0,0,10"/>
                                    <TextBlock>
                                        <Run Text="Период: "/>
                                        <Run Text="{Binding StartDate, StringFormat=dd.MM.yyyy}"/>
                                        <Run Text=" - "/>
                                        <Run Text="{Binding EndDate, StringFormat=dd.MM.yyyy}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding CategoriesInfo}" 
                                               FontSize="12" Foreground="Gray"
                                               TextWrapping="Wrap"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>