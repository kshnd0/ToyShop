<UserControl x:Class="ToyShop.Views.UserControls.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#e1e1e1" CornerRadius="15" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0" Background="#d1eefc" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <TextBlock Text=" Категории товаров" 
                               FontSize="18" FontWeight="Bold" 
                               Foreground="#000000"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnAdd" Content=" Добавить" 
                                Background="#b5d5ca" Foreground="#000000"
                                Padding="12,6" Margin="0,0,10,0" 
                                Cursor="Hand" BorderThickness="0"
                                Click="BtnAdd_Click"/>
                        <Button x:Name="btnEdit" Content=" Редактировать" 
                                Background="#d1eefc" Foreground="#000000"
                                Padding="12,6" Margin="0,0,10,0" 
                                Cursor="Hand" BorderThickness="0"
                                Click="BtnEdit_Click"/>
                        <Button x:Name="btnDelete" Content=" Удалить" 
                                Background="#e0a9af" Foreground="#000000"
                                Padding="12,6" 
                                Cursor="Hand" BorderThickness="0"
                                Click="BtnDelete_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="12" Margin="0,0,0,15">
                <Grid>
                    <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="tbSearch" 
                             TextChanged="TbSearch_TextChanged"
                             ToolTip="Поиск категорий..."
                             FontSize="13"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="30,0,0,0"/>
                </Grid>
            </Border>

            
            <TextBlock x:Name="tbCount" Grid.Row="2" 
                       FontSize="12" Foreground="Gray"
                       Margin="0,0,0,10" HorizontalAlignment="Right"/>

           
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <WrapPanel x:Name="wpCategories" 
                           Orientation="Horizontal"
                           HorizontalAlignment="Center"/>
            </ScrollViewer>

            <TextBlock x:Name="tbStatus" Grid.Row="4" 
                       FontSize="11" Foreground="Gray" 
                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </Grid>
    </Border>
</UserControl>