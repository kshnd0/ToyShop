<Window x:Class="ToyShop.Views.Customer.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Корзина" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#e1e1e1"
        MinHeight="500" MinWidth="700">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20" Margin="0,0,0,20">
            <Grid>
                <TextBlock Text="Моя корзина" FontSize="24" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock x:Name="tbItemsCount" FontSize="14" Foreground="#b5d5ca" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Список товаров -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icCartItems">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                                Margin="0,0,0,10" Padding="15"
                                BorderBrush="#b5d5ca" BorderThickness="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Картинка -->
                                <Image Source="{Binding ImagePath}" 
                                       Width="80" Height="80" 
                                       Stretch="UniformToFill"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"/>

                                <!-- Название и цена -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ProductName}" 
                                               FontSize="16" FontWeight="Bold" 
                                               Foreground="#000000"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:F2} руб.}" 
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#b5d5ca"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <!-- Управление количеством -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" 
                                            VerticalAlignment="Center" Margin="20,0">
                                    <Button Content="-" Width="45" Height="45" 
                                            FontSize="22" FontWeight="Bold"
                                            Background="#d1eefc" Foreground="#000000"
                                            Click="BtnDecrease_Click" 
                                            Tag="{Binding IdBasketProduct}"
                                            Cursor="Hand" BorderThickness="0"/>
                                    <TextBlock Text="{Binding Quantity}" 
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="#000000"
                                               Width="60" TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Tag="{Binding IdBasketProduct}"/>
                                    <Button Content="+" Width="45" Height="45" 
                                            FontSize="22" FontWeight="Bold"
                                            Background="#d1eefc" Foreground="#000000"
                                            Click="BtnIncrease_Click" 
                                            Tag="{Binding IdBasketProduct}"
                                            Cursor="Hand" BorderThickness="0"/>
                                </StackPanel>

                                <!-- Сумма и удаление -->
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" 
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Total, StringFormat={}{0:F2} руб.}" 
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="#2C3E50"
                                               HorizontalAlignment="Right"/>
                                    <Button Content="Удалить" 
                                            Width="90" Height="35" Margin="0,10,0,0"
                                            Background="#e0a9af" Foreground="#000000"
                                            Click="RemoveItem_Click" 
                                            Tag="{Binding IdBasketProduct}"
                                            Cursor="Hand" BorderThickness="0"
                                            FontSize="13"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Итоговая панель -->
        <Border Grid.Row="2" Background="#2C3E50" Padding="20" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="ИТОГО К ОПЛАТЕ" FontSize="14" Foreground="#b5d5ca"/>
                    <TextBlock x:Name="tbTotal" FontSize="28" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnCheckout" Content="ОФОРМИТЬ ЗАКАЗ" 
                            Width="180" Height="45" Margin="0,0,15,0"
                            Click="BtnCheckout_Click" Background="#b5d5ca" Foreground="#000000" 
                            FontWeight="Bold" Cursor="Hand"/>
                    <Button x:Name="btnClose" Content="ЗАКРЫТЬ" 
                            Width="120" Height="45"
                            Click="BtnClose_Click" Background="#e0a9af" Foreground="#000000" 
                            FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>