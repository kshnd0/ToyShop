<UserControl x:Class="ToyShop.Views.UserControls.AddressesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#e1e1e1" CornerRadius="15" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

           
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Button x:Name="btnAdd" Content=" Добавить адрес" 
                        Background="#b5d5ca" Foreground="Black"
                        Padding="15,8" Margin="0,0,10,0" Cursor="Hand"
                        Click="BtnAdd_Click"/>
                <Button x:Name="btnEdit" Content=" Редактировать" 
                        Background="#d1eefc" Foreground="Black"
                        Padding="15,8" Margin="0,0,10,0" Cursor="Hand"
                        Click="BtnEdit_Click"/>
                <Button x:Name="btnDelete" Content=" Удалить" 
                        Background="#e0a9af" Foreground="Black"
                        Padding="15,8" Cursor="Hand"
                        Click="BtnDelete_Click"/>
            </StackPanel>


            <!-- Поиск -->
            <TextBox x:Name="tbSearch" 
         Style="{StaticResource SearchTextBox}"
         Grid.Row="1" 
         Margin="0,0,0,15"
         TextChanged="TbSearch_TextChanged"
         ToolTip="Поиск товаров..."/>


            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icAddresses">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12" 
                                    Margin="10" Padding="15"
                                    BorderBrush="#b5d5ca" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonUp="Card_Click" Tag="{Binding IdAddress}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text=" Адрес доставки" FontSize="12" 
                                                   Foreground="Gray" Margin="0,0,0,5"/>
                                        <TextBlock FontSize="16" FontWeight="Bold" 
                                                   Foreground="Black" Margin="0,0,0,8">
                                            <Run Text="{Binding City}"/>,
                                            <Run Text="ул. "/><Run Text="{Binding Street}"/>,
                                            <Run Text="д. "/><Run Text="{Binding House}"/>
                                            <Run Text="{Binding Apartment, StringFormat=кв. {0}}"/>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Border Background="#d1eefc" CornerRadius="8" Padding="8,3">
                                                <TextBlock Text="{Binding City}" FontSize="11" Foreground="Black"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>