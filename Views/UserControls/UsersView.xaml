<UserControl x:Class="ToyShop.Views.UserControls.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#e1e1e1" CornerRadius="15" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Только кнопка Редактировать -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="btnEdit" Content="Редактировать" 
                        Style="{StaticResource InfoButton}"
                        Click="BtnEdit_Click"/>
            </StackPanel>

            <!-- Поиск -->
            <TextBox x:Name="tbSearch" 
                     Style="{StaticResource SearchTextBox}"
                     Grid.Row="1" 
                     Margin="0,0,0,15"
                     TextChanged="TbSearch_TextChanged"
                     ToolTip="Поиск пользователей..."/>

            <!-- Карточки пользователей -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icUsers">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12" 
                                    Margin="10" Padding="15"
                                    BorderBrush="#b5d5ca" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonUp="Card_Click" Tag="{Binding IdUser}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="ФИО" FontSize="11" Foreground="Gray"/>
                                        <TextBlock Text="{Binding FullName}" FontSize="15" FontWeight="Bold" Foreground="Black"/>

                                        <TextBlock Text="Логин" FontSize="11" Foreground="Gray" Margin="0,10,0,0"/>
                                        <TextBlock Text="{Binding Login}" FontSize="13" Foreground="Black"/>

                                        <TextBlock Text="Email" FontSize="11" Foreground="Gray" Margin="0,10,0,0"/>
                                        <TextBlock Text="{Binding Email}" FontSize="13" Foreground="Black"/>

                                        <TextBlock Text="Телефон" FontSize="11" Foreground="Gray" Margin="0,10,0,0"/>
                                        <TextBlock Text="{Binding Number}" FontSize="13" Foreground="Black"/>

                                        <TextBlock Text="Роль" FontSize="11" Foreground="Gray" Margin="0,10,0,0"/>
                                        <Border Background="#e1fcd6" CornerRadius="10" Padding="8,3" 
                                                HorizontalAlignment="Left" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Role}" FontSize="12" FontWeight="Bold"
                                                       Foreground="Black"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>