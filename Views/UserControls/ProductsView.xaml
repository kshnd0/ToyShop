<UserControl x:Class="ToyShop.Views.UserControls.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#e1e1e1" CornerRadius="15" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="btnAdd" Content="Добавить" 
                        Background="#b5d5ca" Foreground="Black"
                        Padding="15,8" Margin="0,0,10,0" Cursor="Hand"
                        Click="BtnAdd_Click"/>
                <Button x:Name="btnEdit" Content="Редактировать" 
                        Background="#d1eefc" Foreground="Black"
                        Padding="15,8" Margin="0,0,10,0" Cursor="Hand"
                        Click="BtnEdit_Click"/>
                <Button x:Name="btnDelete" Content="Удалить" 
                        Background="#e0a9af" Foreground="Black"
                        Padding="15,8" Margin="0,0,10,0" Cursor="Hand"
                        Click="BtnDelete_Click"/>
                <Button x:Name="btnExport" Content="Экспорт" 
                        Background="#e1fcd6" Foreground="Black"
                        Padding="15,8" Cursor="Hand"
                        Click="BtnExport_Click"/>
                <Button x:Name="btnResetFilter" Content="Сбросить фильтр" 
                        Background="#d1eefc" Foreground="Black"
                        Padding="15,8" Cursor="Hand"
                        Click="BtnResetFilter_Click"
                        Visibility="Collapsed"/>
            </StackPanel>

            <TextBox x:Name="tbSearch" 
                     Grid.Row="1" 
                     Margin="0,0,0,15"
                     Height="35" Padding="10"
                     Background="White"
                     BorderBrush="#b5d5ca"
                     BorderThickness="1"
                     TextChanged="TbSearch_TextChanged"
                     ToolTip="Поиск товаров..."/>

            <TextBlock x:Name="tbCount" Grid.Row="2" 
                       FontSize="12" Foreground="Gray"
                       Margin="0,0,0,10" HorizontalAlignment="Right"/>

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="wpProducts" HorizontalAlignment="Center"/>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>