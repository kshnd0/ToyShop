<UserControl x:Class="ToyShop.Views.UserControls.ProvidersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#e1e1e1" CornerRadius="15" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="btnAdd" Content="Добавить" 
                        Background="#b5d5ca" Foreground="Black"
                        Padding="15,8" Margin="0,0,10,0" Cursor="Hand"
                        Click="BtnAdd_Click"/>
                <Button x:Name="btnEdit" Content="Редактировать" 
                        Background="#d1eefc" Foreground="Black"
                        Padding="15,8" Margin="0,0,10,0" Cursor="Hand"
                        Click="BtnEdit_Click"/>
                <Button x:Name="btnDelete" Content="Удалить" 
                        Background="#e0a9af" Foreground="Black"
                        Padding="15,8" Cursor="Hand"
                        Click="BtnDelete_Click"/>
            </StackPanel>

            <!-- Поиск -->
            <TextBox x:Name="tbSearch" 
         Style="{StaticResource SearchTextBox}"
         Grid.Row="1" 
         Margin="0,0,0,15"
         TextChanged="TbSearch_TextChanged"
         ToolTip="Поиск товаров..."/>
            
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icProviders">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12" 
                                    Margin="10" Padding="15"
                                    BorderBrush="#b5d5ca" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonUp="Card_Click" Tag="{Binding IdProvider}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                        <TextBlock Text="Название" FontSize="11" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" Foreground="Black"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                        <TextBlock Text="Телефон" FontSize="11" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Number}" FontSize="14" Foreground="Black"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="ИНН" FontSize="11" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Inn}" FontSize="14" Foreground="Black"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>