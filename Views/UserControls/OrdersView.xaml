<UserControl x:Class="ToyShop.Views.UserControls.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#e1e1e1" CornerRadius="15" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="btnEdit" Content="Редактировать" 
                        Style="{StaticResource InfoButton}"
                        Margin="0,0,10,0"
                        Click="BtnEdit_Click"/>
            </StackPanel>

            <TextBox x:Name="tbSearch" 
                     Style="{StaticResource SearchTextBox}"
                     Grid.Row="1" 
                     Margin="0,0,0,15"
                     TextChanged="TbSearch_TextChanged"
                     ToolTip="Поиск заказов..."/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icOrders">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="12" 
                                    Margin="10" Padding="15"
                                    BorderBrush="#b5d5ca" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonUp="Card_Click" Tag="{Binding IdOrder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#d1eefc" 
                                            CornerRadius="10" Padding="15" Margin="0,0,15,0"
                                            VerticalAlignment="Center">
                                        <StackPanel>
                                            <TextBlock Text="ЗАКАЗ" FontSize="10" Foreground="Gray"/>
                                            <TextBlock Text="{Binding IdOrder}" FontSize="20" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>

                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,10">
                                            <TextBlock Text="Дата" FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding RegistrationDate}" FontSize="13" Foreground="Black"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,15,10">
                                            <TextBlock Text="Статус" FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Status}" FontSize="13" Foreground="Black"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,15,10">
                                            <TextBlock Text="Оплата" FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding PayMethod}" FontSize="13" Foreground="Black"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,10">
                                            <TextBlock Text="Покупатель" FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding BuyerName}" FontSize="13" Foreground="Black"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,15,10">
                                            <TextBlock Text="Сотрудник" FontSize="11" Foreground="Gray"/>
                                            <TextBlock Text="{Binding EmployeeName}" FontSize="13" Foreground="Black"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>