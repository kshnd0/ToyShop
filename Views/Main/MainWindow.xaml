<Window x:Class="ToyShop.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:ToyShop.Views.UserControls"
        Title="ToyShop" 
        Height="650" 
        Width="1100"
        MinWidth="900"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#e1e1e1"
        Icon="/Images/logo.png">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#b5d5ca"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

       
        <Style x:Key="RoundedButtonDanger" TargetType="Button">
            <Setter Property="Background" Value="#e0a9af"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

       
        <Border Background="#d1eefc" Padding="15" CornerRadius="15,15,15,15" Margin="15,15,15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Border Width="45" Height="45" CornerRadius="10" ClipToBounds="True" Margin="0,0,10,0">
                        <Image Source="/Images/logo.png" 
                               Stretch="UniformToFill" 
                               Width="72" Height="66"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center" 
                               Margin="-23,0,0,0"/>
                    </Border>
                    <TextBlock Text="ToyShop" Foreground="Black" 
                               FontSize="24" FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                </StackPanel>

              
                <TextBlock x:Name="tbUserInfo" Grid.Column="1"
                           HorizontalAlignment="Center" Foreground="#000000" 
                           FontSize="14" VerticalAlignment="Center"/>


                
                <StackPanel Grid.Column="2" Orientation="Horizontal">

                    <Button x:Name="btnCart" Content="Корзина" Click="BtnCart_Click" 
            Style="{StaticResource RoundedButton}" 
            Width="120" Height="40"/>

                    <Separator Width="1" Background="#b5d5ca" Margin="0,5,10,5"/>

                    <Button x:Name="btnLogout" Content="Выход" Click="BtnLogout_Click" 
            Style="{StaticResource RoundedButtonDanger}" 
            Width="95" Height="40"
            Margin="0,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

       
        <TabControl x:Name="MainTab" Grid.Row="1" Margin="15"
                    FontSize="14" FontWeight="SemiBold"
                    Background="Transparent"
                    BorderThickness="0">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="MinWidth" Value="100"/>
                    <Setter Property="Height" Value="45"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Background" Value="#d1eefc"/>
                    <Setter Property="Foreground" Value="#000000"/>
                    <Setter Property="BorderBrush" Value="#b5d5ca"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Margin" Value="2,0"/>
                    <Setter Property="Padding" Value="15,10"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="12,12,0,0"
                                        Margin="2,0">
                                    <ContentPresenter x:Name="ContentSite"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      ContentSource="Header"
                                                      Margin="15,10"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#b5d5ca"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#b5d5ca"/>
                                        <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#e1fcd6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

           
            <TabItem x:Name="tabHome" Header="Главная">
                <Border Background="#e1e1e1" CornerRadius="0,15,15,15" Padding="0">
                    <Grid>
                       
                        <Image Source="/Images/image.jpg" 
                               Stretch="UniformToFill" 
                               Opacity="0.85"/>

                      
                        <Border Background="#80000000"/>

                       
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Border Background="#C02C3E50" 
                                    CornerRadius="25" 
                                    Padding="40,30">
                                <StackPanel>
                                    <TextBlock x:Name="tbWelcome" 
                                               Text="Добро пожаловать!" 
                                               FontSize="36" 
                                               FontWeight="Bold" 
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="ToyShop - управление магазином игрушек" 
                                               FontSize="16" 
                                               Foreground="#e1e1e1"
                                               HorizontalAlignment="Center"
                                               Margin="0,15,0,0"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            
            <TabItem x:Name="tabCategories" Header="Категории">
                <Border Background="#e1e1e1" CornerRadius="0,15,15,15" Padding="10">
                    <ContentControl x:Name="CategoriesContentControl"/>
                </Border>
            </TabItem>

            
            <TabItem x:Name="tabProducts" Header="Товары">
                <Border Background="#e1e1e1" CornerRadius="0,15,15,15" Padding="10">
                    <ContentControl x:Name="ProductsContentControl"/>
                </Border>
            </TabItem>

           
            <TabItem x:Name="tabOrders" Header="Заказы">
                <Border Background="#e1e1e1" CornerRadius="0,15,15,15" Padding="10">
                    <ContentControl x:Name="OrdersContentControl"/>
                </Border>
            </TabItem>

            
            <TabItem x:Name="tabEmployee" Header="Сотрудники">
                <Border Background="#e1e1e1" CornerRadius="0,15,15,15" Padding="10">
                    <ContentControl x:Name="EmployeesContentControl"/>
                </Border>
            </TabItem>

            
            <TabItem x:Name="tabProvider" Header="Поставщики">
                <Border Background="#e1e1e1" CornerRadius="0,15,15,15" Padding="10">
                    <ContentControl x:Name="ProvidersContentControl"/>
                </Border>
            </TabItem>

            
            <TabItem x:Name="tabWarehouse" Header="Склады">
                <Border Background="#e1e1e1" CornerRadius="0,15,15,15" Padding="10">
                    <ContentControl x:Name="WarehousesContentControl"/>
                </Border>
            </TabItem>

           
            <TabItem x:Name="tabStock" Header="Остатки на складах">
                <Border Background="#e1e1e1" CornerRadius="0,15,15,15" Padding="10">
                    <ContentControl x:Name="StockContentControl"/>
                </Border>
            </TabItem>

            
          

           
            <TabItem x:Name="tabUser" Header="Пользователи">
                <Border Background="#e1e1e1" CornerRadius="0,15,15,15" Padding="10">
                    <ContentControl x:Name="UsersContentControl"/>
                </Border>
            </TabItem>

            
            <TabItem x:Name="tabAddresses" Header="Мои адреса">
                <Border Background="#e1e1e1" CornerRadius="0,15,15,15" Padding="10">
                    <ContentControl x:Name="AddressesContentControl"/>
                </Border>
            </TabItem>

            <TabItem x:Name="tabEvents" Header="Акции">
                <ContentControl x:Name="EventsContentControl"/>
            </TabItem>

        </TabControl>

        
        <StatusBar Grid.Row="2" Background="#d1eefc" Padding="10" Margin="15,0,15,15">
            <TextBlock x:Name="tbStatus" FontSize="12" Foreground="#000000"/>
        </StatusBar>
    </Grid>
</Window>