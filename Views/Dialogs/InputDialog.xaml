<Window x:Class="ToyShop.Views.UserControls.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод" Height="210" Width="401"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#e1e1e1"
        Icon="/Images/logo.png">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="tbMessage" Text="Введите значение:" 
                   Margin="0,0,0,10" FontSize="14" Foreground="#000000"/>

        <TextBox x:Name="tbInput" Grid.Row="1" Height="35" FontSize="14" Margin="0,0,0,20"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="35" Margin="0,0,10,0"
                    Click="BtnOk_Click" Background="#b5d5ca" Foreground="#000000"/>
            <Button Content="Отмена" Width="80" Height="35"
                    Click="BtnCancel_Click" Background="#e0a9af" Foreground="#000000"/>
        </StackPanel>
    </Grid>
</Window>