<Window x:Class="ToyShop.Views.UserControls.WarehouseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Склад" Height="368" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#e1e1e1"
        Icon="/Images/logo.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbName" Grid.Row="0" Grid.Column="1" Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Город:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbCity" Grid.Row="1" Grid.Column="1" Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Улица:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbStreet" Grid.Row="2" Grid.Column="1" Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дом:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbHouse" Grid.Row="3" Grid.Column="1" Height="35" Margin="0,0,0,20"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="35" Margin="0,0,10,0"
                    Click="BtnOk_Click" Background="#b5d5ca" Foreground="#000000"/>
            <Button Content="Отмена" Width="80" Height="35"
                    Click="BtnCancel_Click" Background="#e0a9af" Foreground="#000000"/>
        </StackPanel>
    </Grid>
</Window>