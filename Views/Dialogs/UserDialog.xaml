<Window x:Class="ToyShop.Views.UserControls.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование пользователя" Height="450" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#e1e1e1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Телефон -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Телефон:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbNumber" Grid.Row="0" Grid.Column="1" Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <!-- Email -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Email:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbEmail" Grid.Row="1" Grid.Column="1" Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <!-- Роль -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Роль:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <ComboBox x:Name="cbRole" Grid.Row="2" Grid.Column="1" Height="35" Margin="0,0,0,20"
                  Background="#d1eefc">
            <ComboBoxItem Content="Admin"/>
            <ComboBoxItem Content="Manager"/>
            <ComboBoxItem Content="Customer"/>
        </ComboBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="35" Margin="0,0,10,0"
                    Click="BtnOk_Click" Background="#b5d5ca" Foreground="#000000"/>
            <Button Content="Отмена" Width="80" Height="35"
                    Click="BtnCancel_Click" Background="#e0a9af" Foreground="#000000"/>
        </StackPanel>

        <!-- Подсказка о телефоне -->
        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" 
                   Text="Формат телефона: 8-XXX-XXX-XX-XX" 
                   FontSize="11" Foreground="Gray" HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </Grid>
</Window>