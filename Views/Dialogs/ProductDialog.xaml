<Window x:Class="ToyShop.Views.UserControls.ProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="397" Width="476"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#e1e1e1"
        Icon="/Images/logo.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbName" Grid.Row="0" Grid.Column="1" Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Цена:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbCost" Grid.Row="1" Grid.Column="1" Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Производитель:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <TextBox x:Name="tbManufacturer" Grid.Row="2" Grid.Column="1" Height="35" Margin="0,0,0,10"
                 Background="White" BorderBrush="#b5d5ca" BorderThickness="1"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Категория:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <ComboBox x:Name="cbCategory" Grid.Row="3" Grid.Column="1" Height="35" 
                  DisplayMemberPath="Name" SelectedValuePath="IdCategory" Margin="0,0,0,10"
                  Background="#d1eefc"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Поставщик:" 
                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,10"
                   Foreground="#000000"/>
        <ComboBox x:Name="cbProvider" Grid.Row="4" Grid.Column="1" Height="35" 
                  DisplayMemberPath="Name" SelectedValuePath="IdProvider" Margin="0,0,0,20"
                  Background="#d1eefc"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="35" Margin="0,0,10,0"
                    Click="BtnOk_Click" Background="#b5d5ca" Foreground="#000000"/>
            <Button Content="Отмена" Width="80" Height="35"
                    Click="BtnCancel_Click" Background="#e0a9af" Foreground="#000000"/>
        </StackPanel>
    </Grid>
</Window>