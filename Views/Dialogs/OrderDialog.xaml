<Window x:Class="ToyShop.Views.UserControls.OrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение статуса заказа" Height="200" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#e1e1e1">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите новый статус:" FontSize="14" FontWeight="Bold" 
                   Foreground="#000000" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <ComboBox x:Name="cbStatus" Height="35" FontSize="14" Margin="0,0,0,20"
                  Background="White" BorderBrush="#b5d5ca" BorderThickness="1">
            <ComboBoxItem Content="оформлен"/>
            <ComboBoxItem Content="на сборке"/>
            <ComboBoxItem Content="собран"/>
            <ComboBoxItem Content="в пути"/>
            <ComboBoxItem Content="доставлен"/>
            <ComboBoxItem Content="отменен"/>
        </ComboBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="2">
            <Button Content="OK" Width="80" Height="35" Margin="0,0,10,0"
                    Click="BtnOk_Click" Background="#b5d5ca" Foreground="#000000"/>
            <Button Content="Отмена" Width="80" Height="35"
                    Click="BtnCancel_Click" Background="#e0a9af" Foreground="#000000"/>
        </StackPanel>
    </Grid>
</Window>